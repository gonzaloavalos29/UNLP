programa ejercicio3
procesos
  proceso juntarPapeles(ES papelesAct:numero; E papelesMax:numero)
  comenzar
    mientras(HayPapelEnLaEsquina) & (papelesAct < papelesMax)
      tomarPapel
      papelesAct:= papelesAct + 1
  fin
  proceso recorrerAvenida(ES papeles:numero;ES pasos:numero)
  variables
    papelesAct:numero
  comenzar 
    mientras(pasos < 99) & (papelesAct < papeles) 
      juntarPapeles(papelesAct,papeles)
      si(papelesAct < papeles)
        mover
        pasos:= pasos + 1
    papelesAct:=0      
  fin
areas
  ciudad: AreaC(1,1,100,100)
robots
  robot juntador
  variables
    papeles,quien,pasos:numero
    pausa,seguirUno,seguirDos:boolean
  comenzar
    pausa:=V
    seguirUno:=V
    seguirDos:=V
    RecibirMensaje(quien,robot4)
    Random(papeles,1,5)
    recorrerAvenida(papeles,pasos)
    si(pasos < 99)
      mientras(pasos < 99)
        si(quien = 1)
          si(seguirUno = V) & (seguirDos = V)
            EnviarMensaje(pausa,robot2)
            EnviarMensaje(pausa,robot3)
            RecibirMensaje(seguirUno,robot2)
            RecibirMensaje(seguirDos,robot3)
          sino
            si(seguirUno = F) & (seguirDos = V)
              EnviarMensaje(pausa,robot3)
              RecibirMensaje(seguirDos,robot3)
            sino
              si(seguirUno = V) & (seguirDos = F)
                EnviarMensaje(pausa,robot2)
                RecibirMensaje(pausa,robot2)      
        sino
          si(quien = 2)
            si(seguirUno = V) & (seguirDos = V)
              EnviarMensaje(pausa,robot1)
              EnviarMensaje(pausa,robot3)
              RecibirMensaje(seguirUno,robot1)
              RecibirMensaje(seguirDos,robot3)
            sino
              si(seguirUno = F) & (seguirDos = V)
                EnviarMensaje(pausa,robot3)
                RecibirMensaje(seguirDos,robot3)
              sino
                si(seguirUno = V) & (seguirDos = F)
                  EnviarMensaje(pausa,robot1)
                  RecibirMensaje(seguirUno,robot1)
          sino
            si(seguirUno = V) & (seguirDos = V)
              EnviarMensaje(pausa,robot1)
              EnviarMensaje(pausa,robot2)
              RecibirMensaje(seguirUno,robot1)
              RecibirMensaje(seguirDos,robot2)
            sino
              si(seguirUno = F) & (seguirDos = V)
                EnviarMensaje(pausa,robot2)
                RecibirMensaje(seguirDos,robot2)
              sino
                si(seguirUno = V) & (seguirDos = F)
                  EnviarMensaje(pausa,robot1)
                  RecibirMensaje(seguirUno,robot1)
        Random(papeles,1,5)
        recorrerAvenida(papeles,pasos)  
    sino    
      si(quien = 1)
        si(seguirUno = V) & (seguirDos = V)
          EnviarMensaje(F,robot2)
          EnviarMensaje(F,robot3)
        sino
          si(seguirUno = V)
            EnviarMensaje(F,robot2)
          sino
            EnviarMensaje(F,robot3)  
      sino
        si(quien = 2)
          si(seguirUno = V) & (seguirDos = V)
            EnviarMensaje(F,robot1)
            EnviarMensaje(F,robot3)
          sino
            si(seguirUno = V)
              EnviarMensaje(F,robot1)
            sino
              EnviarMensaje(F,robot3)
        sino
          si(seguirUno = V) & (seguirDos = V)        
            EnviarMensaje(F,robot1)
            EnviarMensaje(F,robot2)
          sino
            si(seguirUno = V)
              EnviarMensaje(F,robot1)
            sino
              EnviarMensaje(F,robot2)                                
  fin
  robot coordinador
  comenzar
    EnviarMensaje(1,robot1)
    EnviarMensaje(2,robot2)
    EnviarMensaje(3,robot3)
  fin
variables
  robot1:juntador
  robot2:juntador
  robot3:juntador
  robot4:coordinador
comenzar
  AsignarArea(robot1,ciudad)
  AsignarArea(robot2,ciudad)
  AsignarArea(robot3,ciudad)
  AsignarArea(robot4,ciudad)
  Iniciar(robot1,1,1)
  Iniciar(robot2,2,1)
  Iniciar(robot3,3,1)
  Iniciar(robot4,100,100)
fin

    
      
    
    
                 